# SERVITOR config — copy to .env and fill in.

# Discord bot token (Developer Portal → Applications → Bot → Reset Token)
DISCORD_BOT_TOKEN=PASTE_TOKEN_HERE

# Local Ollama endpoint
OLLAMA_URL=http://localhost:11434/api/chat

# Pulled model (must already be `ollama pull`ed)
MODEL_NAME=huihui_ai/qwen2.5-coder-abliterate:7b

# Vision model — used automatically when an image is attached.
# Must support Ollama's `images` field (qwen2.5-vl, llava, llama3.2-vision, etc.)
VISION_MODEL_NAME=huihui_ai/qwen2.5-vl-abliterated:7b

# Trigger words — start of a message means "talk to me" (used with AUTHORISED_ROLES)
BOT_TRIGGER_NAMES=servitor,spirit,machine,omnissiah,omnisiah

# Server roles that can speak to the bot via trigger words
AUTHORISED_ROLES=admin

# Discord usernames (lowercase) that bypass triggers — the bot answers them automatically
WHITELIST_USERS=

# Discord usernames (lowercase) the bot ignores entirely. Overrides whitelist.
BLACKLIST_USERS=

# Webhook/bot usernames allowed to talk to SERVITOR (normally bots are ignored).
# Useful for automated test rigs or remote diagnostics. Leave blank for production.
ALLOW_BOT_USERNAMES=

# Rolling channel memory (per-channel, last N user msgs + N bot replies)
HISTORY_DEPTH=12

# Ollama HTTP timeout in seconds
REQUEST_TIMEOUT=600

# === WEBSEARCH (DuckDuckGo via ddgs) ===
# Master switch. Set false to disable sentinel interception entirely.
SEARCH_ENABLED=true
# Max searches per single user message (prevents runaway loops).
SEARCH_MAX_LOOPS=3
# Number of organic results returned per search (ad-filtered).
SEARCH_MAX_RESULTS=5

# === VISION via Anthropic API (optional) ===
# Cheap escape from local-GPU constraints — vision routes to Claude when
# VISION_MODEL_NAME starts with "anthropic:". Cost ~$0.001-0.005 per image.
# Set VISION_MODEL_NAME=anthropic:claude-haiku-4-5 (or claude-sonnet-4-6) above.
# Leave blank to keep vision local via Ollama.
ANTHROPIC_API_KEY=
ANTHROPIC_MAX_TOKENS=1024
