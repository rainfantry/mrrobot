Modelfile.*

# ComfyUI workflow files — per-bot config (Verena bot uses LoRA + portrait;
# generic agent uses no-LoRA + square). Tracked .example versions are the
# defaults; copy to .json on first clone + customize per bot.
gen_template.json
scene_template.json

# Runtime logs
bot.log
bot.stdout.log

# ComfyUI bridge test artifacts (generated by `python comfyui_bridge.py "..."`)
test_gen.png
test_gen*.png
*.png

# Live editable system prompt — private to each operator's rig.
# Bot reads it at startup with a fallback to SYSTEM_PROMPT_BASELINE in mrrobot.py.
# Covers system_prompt.txt + any backup variants (timestamped, "- Copy", .bak, etc).
system_prompt*.txt
prompt_*.txt
# Exception: the public template is tracked so cloners have a starting point.
!system_prompt.example.txt

# ASF (Adversarial Survival Framework) — personal psychological framework, private.
asf_framework.txt

# Pre-extraction backups (safe to delete once the new layout is trusted)
*.bak_pre_extract

# Diagnostic / one-off scripts that may carry personal context
oracle_diag_post.py

# Saved PDF copies of README from GitHub view
mrrobot_README*.pdf
